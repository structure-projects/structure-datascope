<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.structured.datascope.example.mybatisplus.mapper.OrderMapper">

    <!-- 根据订单编号查询 -->
    <select id="selectByOrderNo" resultType="cn.structured.datascope.example.mybatisplus.entity.OrderEntity">
        SELECT * FROM orders WHERE order_no = #{orderNo}
    </select>

    <!-- 根据订单编号列表批量查询 -->
    <select id="selectByOrderNos" resultType="cn.structured.datascope.example.mybatisplus.entity.OrderEntity">
        SELECT * FROM orders WHERE order_no IN
        <foreach collection="orderNos" item="orderNo" open="(" separator="," close=")">
            #{orderNo}
        </foreach>
    </select>

    <!-- 条件查询订单 -->
    <select id="selectByCondition" resultType="cn.structured.datascope.example.mybatisplus.entity.OrderEntity">
        SELECT * FROM orders
        <where>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

</mapper>
